{
  "name": "repowright-backend",
  "version": "0.1.0",
  "description": "RepoWright workspace service (API server + web UI)",
  "type": "module",
  "bin": {
    "repowright": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "drizzle-orm": "^0.38.0",
    "express": "^5.2.1",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0"
  }
}
