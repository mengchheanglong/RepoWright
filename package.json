{
  "name": "repowright",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first source code analysis workbench with API and web interface",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter repowright-backend dev",
    "ui:dev": "pnpm --filter repowright-frontend dev",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm ui:dev\"",
    "build": "pnpm -r build",
    "test": "pnpm --filter repowright-backend test",
    "lint": "pnpm --filter repowright-backend lint",
    "lint:fix": "pnpm --filter repowright-backend lint:fix",
    "format": "pnpm --filter repowright-backend format",
    "clean": "node -e \"const fs=require('node:fs'); for (const dir of ['backend/dist','frontend/dist','coverage']) fs.rmSync(dir,{recursive:true,force:true});\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
